<details class="ps_checkout-fastlane-email-info">
  <summary class="fastlane-summary">
    <i class="material-icons fastlane-toggle-icon">keyboard_arrow_down</i>

    <div>
      <p class="fastlane-summary-title">{l s='Save your order information with Fastlane' mod='ps_checkout'}</p>
      <p class="fastlane-summary-subtext">{l s='Continue as a guest by writing your email address in the field above.' mod='ps_checkout'}</p>
    </div>

    <div id="fastlane-email-watermark">
      <img alt="PayPal watermark" src="https://www.paypalobjects.com/fastlane-v1/assets/fastlane-with-tooltip_en_sm_light.0808.svg" />
    </div>
  </summary>

  <div class="fastlane-dropdown-content">
    <p>{l s='Your information will be pre-filled if you already have a PayPal or Fastlane account.' mod='ps_checkout'}</p>
    <p>{l s='If not, you can decide to save all your order information at the payment step and have them pre-filled on any store using Fastlane in the future.' mod='ps_checkout'}</p>
  </div>
</details>
