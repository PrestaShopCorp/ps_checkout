{
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true,
        "prepend-autoloader": false,
        "platform-check": false
    },
    "require": {
        "php": "^7.2.5|^8.1",
        "ext-json": "*",
        "ext-openssl": "*",
        "giggsey/libphonenumber-for-php": "^8.12",
        "prestashop/module-lib-guzzle-adapter": "^1.0",
        "prestashop/module-lib-mbo-installer": "^3",
        "prestashop/module-lib-service-container": "^2.0",
        "prestashop/prestashop-accounts-installer": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5|^8.5",
        "prestashop/php-dev-tools": "^4.2|^3.16",
        "stancer/php-stubs-prestashop": "^8.2.2"
    },
    "conflict": {
        "webmozart/assert": "*"
    },
    "scripts": {
        "phpstan": "../vendor/bin/phpstan analyse --memory-limit=1G",
        "phpstan:baseline": "@phpstan --generate-baseline",
        "phpstan:ci": "@phpstan --error-format=github"
    },
    "autoload": {
        "psr-4": {
            "PsCheckout\\Module\\": "src/",
            "PsCheckout\\Presentation\\": "vendor/invertus/presentation/src/",
            "PsCheckout\\Infrastructure\\": "vendor/invertus/infrastructure/src/",
            "PsCheckout\\Core\\": "vendor/invertus/core/src/",
            "PsCheckout\\Utility\\": "vendor/invertus/utility/src/",
            "PsCheckout\\Api\\": "vendor/invertus/api/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PsCheckout\\Tests\\": "tests/",
            "PsCheckout\\Core\\Tests\\Integration\\": "vendor/invertus/core/tests/Integration"
        }
    },
    "authors": [
        {
            "name": "PrestaShop SA",
            "email": "contact@prestashop.com"
        }
    ],
    "license": "AFL-3.0"
}
